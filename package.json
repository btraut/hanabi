{
	"name": "hanabi",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"license": "MIT",
	"packageManager": "pnpm@10.11.0",
	"scripts": {
		"dev": "node scripts/dev-runtime.mjs start",
		"dev:services": "nx run-many -t dev --projects web,server --parallel",
		"dev:status": "node scripts/dev-runtime.mjs status",
		"dev:down": "node scripts/dev-runtime.mjs down",
		"build": "nx run-many -t build --exclude hanabi",
		"test": "vitest run",
		"lint": "nx run-many -t lint --exclude hanabi",
		"lint:fix": "nx run-many -t lint --exclude hanabi -- --fix",
		"typecheck": "nx run-many -t typecheck --exclude hanabi",
		"format": "prettier --cache --write .",
		"format:check": "prettier --cache --check .",
		"graph": "nx graph",
		"clean": "rimraf ./dist"
	},
	"devDependencies": {
		"@eslint/js": "^9.17.0",
		"@nx/eslint": "^20.3.0",
		"@types/node": "^24.13.3",
		"esbuild": "^0.28.1",
		"eslint": "^9.17.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-react-hooks": "^7.1.1",
		"nx": "^20.3.0",
		"prettier": "^3.9.5",
		"rimraf": "^6.1.3",
		"tsx": "^4.23.1",
		"typescript": "^5.7.2",
		"typescript-eslint": "^8.64.0",
		"vitest": "4.1.10"
	},
	"nx": {}
}

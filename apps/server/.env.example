# Server Configuration
NODE_ENV=development
PORT=3000

# Session
# Generate one with: openssl rand -base64 48
SESSION_COOKIE_SECRET=change-me

# Game Storage: 'file' or 'redis'
GAME_STORE=file
# Production file storage is ephemeral and requires explicit acknowledgement:
# ALLOW_FILE_GAME_STORE=true

# Redis (only needed if GAME_STORE=redis)
REDIS_URL=redis://localhost:6379

# URL Configuration (optional)
DOMAIN_BASE=http://localhost:3000
REDIRECT_URL_PROTOCOL_AND_SUBDOMAIN=

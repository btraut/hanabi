DOMAIN_BASE=http://localhost:3000
PORT=3000

# NODE_ENV=production
NODE_ENV=development

REDIRECT_URL_PROTOCOL_AND_SUBDOMAIN=1

# Generate one with: openssl rand -base64 48
SESSION_COOKIE_SECRET=change-me

NGROK_AUTH_TOKEN=enter-auth-token-here

# Production must explicitly choose file or redis. File storage is ephemeral and also requires
# ALLOW_FILE_GAME_STORE=true.
# GAME_STORE=file
# ALLOW_FILE_GAME_STORE=true
GAME_STORE=redis

REDIS_URL=redis://127.0.0.1:6379
